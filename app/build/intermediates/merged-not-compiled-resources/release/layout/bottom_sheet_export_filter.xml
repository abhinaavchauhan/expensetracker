<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:background="@drawable/bg_bottom_sheet_dark">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@drawable/bg_handle_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Download Statement"
        android:textColor="@color/text_primary_dark"
        android:textSize="@dimen/text_title"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="@dimen/spacing_xs" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select custom range or use quick filters"
        android:textColor="@color/text_tertiary_dark"
        android:textSize="@dimen/text_body"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Custom Date Range -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <LinearLayout
            android:id="@+id/ll_from_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_input_dark"
            android:padding="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From Date"
                android:textColor="@color/text_tertiary_dark"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_from_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Date"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_to_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_input_dark"
            android:padding="@dimen/spacing_md"
            android:layout_marginStart="@dimen/spacing_xs"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To Date"
                android:textColor="@color/text_tertiary_dark"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_to_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Date"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Quick Options -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick Options"
        android:textColor="@color/text_secondary_dark"
        android:textSize="11sp"
        android:fontFamily="sans-serif-bold"
        android:textAllCaps="true"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cg_quick_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="@dimen/spacing_lg">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_last_7_days"
            style="@style/FilterChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last 7 Days" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_last_30_days"
            style="@style/FilterChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last 30 Days"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_this_month"
            style="@style/FilterChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This Month" />
            
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_last_month"
            style="@style/FilterChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Month" />
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_generate_pdf"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Generate PDF Report"
        android:textColor="@color/white"
        android:textSize="@dimen/text_subtitle"
        android:fontFamily="sans-serif-bold"
        app:cornerRadius="@dimen/corner_medium"
        app:backgroundTint="@color/primary"
        app:icon="@drawable/ic_export"
        app:iconTint="@color/white"
        app:iconGravity="textStart" />

    <ProgressBar
        android:id="@+id/pb_exporting"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/spacing_md"
        android:visibility="gone"
        android:indeterminateTint="@color/primary" />

</LinearLayout>
