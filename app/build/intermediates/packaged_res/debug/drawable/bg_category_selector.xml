<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/category_selected_bg" />
            <stroke android:width="2dp" android:color="@color/category_selected_stroke" />
            <corners android:radius="@dimen/corner_medium" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_elevated_dark" />
            <corners android:radius="@dimen/corner_medium" />
        </shape>
    </item>
</selector>
