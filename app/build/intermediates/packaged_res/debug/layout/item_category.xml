<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/category_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_category_selector"
    android:padding="@dimen/spacing_sm">

    <FrameLayout
        android:layout_width="@dimen/category_icon_bg"
        android:layout_height="@dimen/category_icon_bg"
        android:layout_marginBottom="@dimen/spacing_xs">

        <View
            android:id="@+id/icon_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_category_icon" />

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="@dimen/icon_medium"
            android:layout_height="@dimen/icon_medium"
            android:layout_gravity="center"
            app:tint="@color/white"
            android:contentDescription="@string/cd_category_icon" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary_dark"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
