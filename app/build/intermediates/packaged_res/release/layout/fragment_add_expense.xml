<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:background="@drawable/bg_input_dark"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/cd_back"
                app:tint="@color/text_primary_dark" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/add_expense"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_title"
                android:fontFamily="sans-serif-medium" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <!-- Type Toggle (Income/Expense) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="4dp"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:id="@+id/btn_expense_type"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/expense"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_gradient_card" />

            <TextView
                android:id="@+id/btn_income_type"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/income"
                android:textColor="@color/text_secondary_dark"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Amount Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_dark"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_amount"
                android:textColor="@color/text_secondary_dark"
                android:textSize="@dimen/text_body"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/currency_symbol"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_display"
                    android:fontFamily="sans-serif-bold" />

                <EditText
                    android:id="@+id/et_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="100dp"
                    android:hint="@string/amount_hint"
                    android:textColorHint="@color/text_tertiary_dark"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_amount_large"
                    android:fontFamily="sans-serif-bold"
                    android:inputType="numberDecimal"
                    android:background="@null"
                    android:maxLines="1"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Category Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_category"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_subtitle"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- Date -->
        <LinearLayout
            android:id="@+id/ll_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:src="@drawable/ic_calendar"
                app:tint="@color/primary"
                android:contentDescription="@string/select_date" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:text="@string/select_date"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_body" />

            <ImageView
                android:layout_width="@dimen/icon_small"
                android:layout_height="@dimen/icon_small"
                android:src="@drawable/ic_dropdown"
                app:tint="@color/text_secondary_dark"
                android:contentDescription="@string/select_date" />
        </LinearLayout>

        <!-- Note -->
        <EditText
            android:id="@+id/et_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:hint="@string/add_note"
            android:textColorHint="@color/text_tertiary_dark"
            android:textColor="@color/text_primary_dark"
            android:textSize="@dimen/text_body"
            android:background="@drawable/bg_card_dark"
            android:padding="@dimen/card_padding"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/save"
            android:textColor="@color/white"
            android:textSize="@dimen/text_subtitle"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/corner_medium" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
