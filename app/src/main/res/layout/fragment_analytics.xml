<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/spacing_xxl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/analytics"
            android:textColor="@color/text_primary_dark"
            android:textSize="@dimen/text_headline"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Period Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_period"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_card_dark"
            app:tabIndicatorColor="@color/primary"
            app:tabSelectedTextColor="@color/primary"
            app:tabTextColor="@color/text_secondary_dark"
            app:tabIndicatorFullWidth="false"
            app:tabRippleColor="@color/ripple_dark"
            app:tabMode="fixed"
            app:tabGravity="fill"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Spending Trend (Bar Chart) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/spending_trend"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_subtitle"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/bar_chart"
                android:layout_width="match_parent"
                android:layout_height="@dimen/chart_height" />
        </LinearLayout>

        <!-- Category Distribution (Pie Chart) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_distribution"
                android:textColor="@color/text_primary_dark"
                android:textSize="@dimen/text_subtitle"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pie_chart"
                android:layout_width="match_parent"
                android:layout_height="@dimen/chart_height" />
        </LinearLayout>

        <!-- Insight Cards -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights"
            android:textColor="@color/text_primary_dark"
            android:textSize="@dimen/text_subtitle"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_sm">

            <!-- Top Category -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_spending"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_top_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="@dimen/text_subtitle"
                    android:fontFamily="sans-serif-medium"
                    android:text="—" />
            </LinearLayout>

            <!-- Avg Daily -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="@dimen/spacing_md"
                android:layout_marginStart="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/avg_daily"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_avg_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="@dimen/text_subtitle"
                    android:fontFamily="sans-serif-medium"
                    android:text="₹0" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Total Transactions -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_transactions"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_total_transactions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="@dimen/text_subtitle"
                    android:fontFamily="sans-serif-medium"
                    android:text="0" />
            </LinearLayout>

            <!-- Budget Used -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="@dimen/spacing_md"
                android:layout_marginStart="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/budget_used"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_budget_used"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="@dimen/text_subtitle"
                    android:fontFamily="sans-serif-medium"
                    android:text="0%" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
